# ============================================
# Backend Environment Configuration Example
# Copy this file to .env and fill in real values.
# NEVER commit the real .env file.
# ============================================

# Server
PORT=3000
NODE_ENV=development

# Database (MySQL)
DATABASE_URL="mysql://user:password@localhost:3306/nexora_db"

# JWT — MUST be at least 32 characters in production.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret-min-32-chars
JWT_EXPIRES_IN=7d

# CORS — the frontend origin
CORS_ORIGIN=http://localhost:5173

# Logging level: debug | info | warn | error
LOG_LEVEL=info