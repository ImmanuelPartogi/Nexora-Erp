# ============================================
# .gitignore - Nexora ERP
# SECURITY: Ensures secrets and build artifacts are never committed
# ============================================

# ── Dependencies ─────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Environment files (NEVER COMMIT SECRETS) ─
.env
.env.*
!.env.example
!.env.test

# ── Build output ─────────────────────────────
dist/
build/
*.tsbuildinfo

# ── Logs ─────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── OS files ─────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE / Editor ─────────────────────────────
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*~

# ── Testing / Coverage ───────────────────────
coverage/
.nyc_output/

# ── Prisma ───────────────────────────────────
backend/prisma/migrations/dev.db*

# ── Misc ─────────────────────────────────────
.env.local
.env.development.local
.env.test.local
.env.production.local